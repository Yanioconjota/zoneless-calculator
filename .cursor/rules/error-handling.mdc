## Optimistic Updates with Rollback

```typescript
withMethods((store, api = inject(ApiService)) => ({
  
  async deleteItem(id: string) {
    // Store current state for rollback
    const previousItems = store.items();
    
    // Optimistic update
    patchState(store, {
      items: previousItems.filter(item => item.id !== id)
    });
    
    try {
      await firstValueFrom(api.delete(id));
      // Success - optimistic update stands
    } catch (error) {
      // Rollback on failure
      patchState(store, { 
        items: previousItems,
        error: 'Failed to delete item'
      });
      throw error;
    }
  },
  
  async updateItem(id: string, changes: Partial<Item>) {
    const previousItems = store.items();
    
    // Optimistic update
    patchState(store, {
      items: previousItems.map(item =>
        item.id === id ? { ...item, ...changes } : item
      )
    });
    
    try {
      await firstValueFrom(api.update(id, changes));
    } catch (error) {
      patchState(store, { items: previousItems, error: 'Failed to update' });
      throw error;
    }
  }
}))
```

## Global Error Boundary

```typescript
// app.config.ts
export const appConfig: ApplicationConfig = {
  providers: [
    {
      provide: ErrorHandler,
      useClass: GlobalErrorHandler
    }
  ]
};

// core/services/global-error-handler.ts
@Injectable()
export class GlobalErrorHandler implements ErrorHandler {
  private readonly notificationService = inject(NotificationService);
  private readonly loggingService = inject(LoggingService);
  
  handleError(error: unknown): void {
    console.error('Unhandled error:', error);
    
    // Log to monitoring service
    this.loggingService.logError(error);
    
    // Show user-friendly message
    this.notificationService.showError(
      'An unexpected error occurred. Please try again.'
    );
  }
}
```

## Rationale

1. **User confidence** - Clear loading and error states build trust
2. **Recoverability** - Retry mechanisms and rollbacks prevent data loss
3. **Debuggability** - Centralized error handling simplifies troubleshooting
4. **Accessibility** - Role alerts ensure errors are announced to screen readers
