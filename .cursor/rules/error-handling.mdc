        <span class="sr-only">{{ loadingText() }}</span>
      } @else {
        <ng-content />
      }
    </button>
  `
})
export class LoadingButtonComponent {
  type = input<'button' | 'submit'>('button');
  loading = input(false);
  disabled = input(false);
  loadingText = input('Loading...');
}
```

