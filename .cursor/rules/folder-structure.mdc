в”‚   в”‚   в”њв”Ђв”Ђ dashboard-container/    # Smart component
в”‚   в”‚   в”њв”Ђв”Ђ stats-card/             # Dumb component
в”‚   в”‚   в”њв”Ђв”Ђ activity-feed/          # Dumb component
в”‚   в”‚   в””в”Ђв”Ђ quick-actions/          # Dumb component
в”‚   в”њв”Ђв”Ђ store/
в”‚   в”‚   в””в”Ђв”Ђ dashboard.store.ts
в”‚   в”њв”Ђв”Ђ models/
в”‚   в”‚   в””в”Ђв”Ђ dashboard.models.ts
в”‚   в””в”Ђв”Ђ dashboard.routes.ts
в”‚
в”њв”Ђв”Ђ products/
в”‚   в”њв”Ђв”Ђ components/
в”‚   в”‚   в”њв”Ђв”Ђ product-list-container/
в”‚   в”‚   в”њв”Ђв”Ђ product-card/
в”‚   в”‚   в”њв”Ђв”Ђ product-filters/
в”‚   в”‚   в”њв”Ђв”Ђ product-detail/
в”‚   в”‚   в””в”Ђв”Ђ product-form/
в”‚   в”њв”Ђв”Ђ services/
